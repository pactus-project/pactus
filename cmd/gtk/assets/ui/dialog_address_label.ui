<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0.2 -->
<interface>
  <requires lib="gtk" version="4.14"/>
  <object class="GtkWindow" id="id_dialog_address_label">
    <property name="default-width">320</property>
    <property name="title">Update Label</property>
    <child>
      <object class="GtkBox">
        <property name="css-classes">dialog-box</property>
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkGrid">
            <property name="css-classes">dialog-grid</property>
            <property name="column-spacing">8</property>
            <property name="row-spacing">8</property>
            <child>
              <object class="GtkLabel">
                <property name="halign">start</property>
                <property name="label">Enter label for the address:</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">0</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkEntry" id="id_entry_label">
                <property name="width-chars">32</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">1</property>
                </layout>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkSeparator"/>
        </child>
        <child>
          <object class="GtkBox">
            <property name="css-classes">dialog-action-bar</property>
            <property name="halign">end</property>
            <property name="spacing">4</property>
            <child>
              <object class="GtkButton" id="id_button_cancel">
              </object>
            </child>
            <child>
              <object class="GtkButton" id="id_button_ok">
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
