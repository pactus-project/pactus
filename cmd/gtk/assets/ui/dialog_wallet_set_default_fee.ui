<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0.2 -->
<interface>
  <!-- interface-name dialog_wallet_set_default_fee.ui -->
  <requires lib="gtk" version="4.14"/>
  <object class="GtkWindow" id="id_dialog_wallet_set_default_fee">
    <property name="default-width">320</property>
    <property name="title">Set Default Fee</property>
    <child>
      <object class="GtkBox">
        <property name="css-classes">dialog-box</property>
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkGrid">
            <property name="css-classes">dialog-grid</property>
            <property name="column-spacing">8</property>
            <property name="row-spacing">8</property>
            <child>
              <object class="GtkLabel">
                <property name="halign">start</property>
                <property name="label">Default Fee (PAC):</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">0</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkEntry" id="id_entry_default_fee">
                <property name="activates-default">True</property>
                <property name="input-purpose">number</property>
                <property name="width-chars">24</property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">0</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="id_label_current_fee">
                <property name="halign">start</property>
                <property name="label">Current:</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">1</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="id_label_current_fee_value">
                <property name="halign">start</property>
                <property name="label">0.01 PAC</property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">1</property>
                </layout>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkSeparator"/>
        </child>
        <child>
          <object class="GtkBox">
            <property name="css-classes">dialog-action-bar</property>
            <property name="halign">end</property>
            <property name="spacing">4</property>
            <child>
              <object class="GtkButton" id="id_button_cancel">
              </object>
            </child>
            <child>
              <object class="GtkButton" id="id_button_ok">
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
